<https://openenergyplatform.org/metadata/v20.owl.ttl> a owl:Ontology ;
    rdfs:label "oemetadata_v20" .

oep:Dataset a owl:Class ;
    rdfs:label "Dataset" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oep:Resource ;
            owl:onProperty oep:resources ],
        [ a owl:Restriction ;
