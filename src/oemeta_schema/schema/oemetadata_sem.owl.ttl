            owl:onProperty oep:sourcelicense_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:sourcelicense_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:path ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:path ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:copyrightStatement ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:instruction ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:sourcelicense_title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:copyrightStatement ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:attribution ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:instruction ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:copyrightStatement ] ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:Spatial a owl:Class ;
    rdfs:label "Spatial" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oep:Extent ;
            owl:onProperty oep:extent ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:location ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:extent ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:extent ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:location ],
        [ a owl:Restriction ;
            owl:allValuesFrom oep:Location ;
            owl:onProperty oep:location ] ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:Subject a owl:Class ;
    rdfs:label "Subject" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:subject_name ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:subject_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:subject_name ] ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:Temporal a owl:Class ;
    rdfs:label "Temporal" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:referenceDate ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:referenceDate ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:timeseries ],
        [ a owl:Restriction ;
            owl:allValuesFrom oep:Timeserie ;
            owl:onProperty oep:timeseries ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:referenceDate ] ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:Timeserie a owl:Class ;
    rdfs:label "Timeserie" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:aggregationType ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:resolutionUnit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:resolutionValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:alignment ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:alignment ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:resolutionUnit ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:resolutionUnit ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:start ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:aggregationType ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:start ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:aggregationType ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:end ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:start ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:end ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:end ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:resolutionValue ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:resolutionValue ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:alignment ] ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:Valuereference a owl:Class ;
    rdfs:label "Valuereference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:valuereference_name ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:valuereference_name ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:valuereference_name ] ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:authors a owl:DatatypeProperty ;
    rdfs:label "authors" ;
    skos:definition "An array of the full names of the authors of the source material." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:boundingBox a owl:DatatypeProperty ;
    rdfs:label "boundingBox" ;
    skos:definition "The covered area specified by the coordinates of a bounding box. The format is [minLon, minLat, maxLon, maxLat] or [W,S,E,N]." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:contributors a owl:ObjectProperty ;
    rdfs:label "contributors" ;
    rdfs:range oep:Contributor ;
    skos:definition "An array of objects of contributors and contributions to the data or metadata." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:foreignKeys a owl:ObjectProperty ;
    rdfs:label "foreignKeys" ;
    rdfs:range oep:Foreignkey ;
    skos:definition "List of foreign keys." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:isAbout a owl:ObjectProperty ;
    rdfs:label "isAbout" ;
    rdfs:range oep:Isabout ;
    skos:definition "An array of objects that describes the field in ontology terms." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:keywords a owl:DatatypeProperty ;
    rdfs:label "keywords" ;
    skos:definition "An array of freely selectable keywords that help with searching and structuring." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:languages a owl:DatatypeProperty ;
    rdfs:label "languages" ;
    skos:definition "An array of languages used within the described data structures (e.g. titles, descriptions) or metadata." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:licenses a owl:ObjectProperty ;
    rdfs:label "licenses" ;
    rdfs:range oep:License ;
    skos:definition "An array of objects of licenses under which the described data is provided." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:primaryKey a owl:DatatypeProperty ;
    rdfs:label "primaryKey" ;
    skos:definition "An array of fields that uniquely identifies each row in the table." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:resources a owl:ObjectProperty ;
    rdfs:label "resources" ;
    rdfs:range oep:Resource ;
    skos:definition "A collection of related resources." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:roles a owl:DatatypeProperty ;
    rdfs:label "roles" ;
    skos:definition "An array describing the roles of the contributor." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:sourceLicenses a owl:ObjectProperty ;
    rdfs:label "sourceLicenses" ;
    rdfs:range oep:Sourcelicense ;
    skos:definition "No description provided." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:sources a owl:ObjectProperty ;
    rdfs:label "sources" ;
    rdfs:range oep:Source ;
    skos:definition "An array of objects with the used and underlying sources of the data and metadata." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:subject a owl:ObjectProperty ;
    rdfs:label "subject" ;
    rdfs:range oep:Subject ;
    skos:definition "An array of objects that references to the subjects of the resource in ontology terms." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:timeseries a owl:ObjectProperty ;
    rdfs:label "timeseries" ;
    rdfs:range oep:Timeserie ;
    skos:definition "An array that describe the timeseries." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:topics a owl:DatatypeProperty ;
    rdfs:label "topics" ;
    skos:definition "An array of predefined topics that correspond to the database schemas of the OEP." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:valueReference a owl:ObjectProperty ;
    rdfs:label "valueReference" ;
    rdfs:range oep:Valuereference ;
    skos:definition "An array of objects for an extended description of the values in the column in ontology terms." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:address a owl:DatatypeProperty ;
    rdfs:label "address" ;
    skos:definition "An address of the location of the data. May be specified with street name, house number, zip code, and city name." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:aggregationType a owl:DatatypeProperty ;
    rdfs:label "aggregationType" ;
    skos:definition "An indicator of whether the values are a sum, an average or a current value." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:alignment a owl:DatatypeProperty ;
    rdfs:label "alignment" ;
    skos:definition "An indicator of whether timestamps in a time series are to the left, right or in the centre." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:badge a owl:DatatypeProperty ;
    rdfs:label "badge" ;
    skos:definition "A badge of either Iron, Bronze, Silver, Gold or Platinum is used to label the quality of the metadata." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:comment a owl:DatatypeProperty ;
    rdfs:label "comment" ;
    skos:definition "A free-text commentary on what has been done." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:contact a owl:DatatypeProperty ;
    rdfs:label "contact" ;
    skos:definition "A reference to the creator or maintainer of the data set. This can be an email address or a GitHub handle." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:context a owl:ObjectProperty ;
    rdfs:label "context" ;
    rdfs:range oep:Context ;
    skos:definition "An Object that describes the general setting, environment or project leading to the creation or maintenance of this dataset. In science this can be the research project." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:context_title a owl:DatatypeProperty ;
    rdfs:label "context_title" ;
    skos:definition "A title of the associated project." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:contributor_title a owl:DatatypeProperty ;
    rdfs:label "contributor_title" ;
    skos:definition "A full name of the contributor." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:crs a owl:DatatypeProperty ;
    rdfs:label "crs" ;
    skos:definition "The Coordinate Reference System, specified as an EPSG code." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:dataset_description a owl:DatatypeProperty ;
    rdfs:label "dataset_description" ;
    skos:definition "A free text description of the dataset." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:dataset_name a owl:DatatypeProperty ;
    rdfs:label "dataset_name" ;
    skos:definition "A filename or database conform dataset name." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:dataset_title a owl:DatatypeProperty ;
    rdfs:label "dataset_title" ;
    skos:definition "A human readable dataset name." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:date a owl:DatatypeProperty ;
    rdfs:label "date" ;
    skos:definition "The date of the contribution. Date Format is ISO 8601." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:decimalSeparator a owl:DatatypeProperty ;
    rdfs:label "decimalSeparator" ;
    skos:definition "The symbol used to separate the integer part from the fractional part of a number written in decimal form. Depending on language and region this symbol can be '.' or ','." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:delimiter a owl:DatatypeProperty ;
    rdfs:label "delimiter" ;
    skos:definition "The delimiter specifies the character sequence which should separate fields (columns). Common characters are ',' (comma), ';' (semicolon), '.' (point) and '\\t' (tab)." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:dialect a owl:ObjectProperty ;
    rdfs:label "dialect" ;
    rdfs:range oep:Dialect ;
    skos:definition "The Dialect defines a simple format for describing the various dialects of CSV files in a language-independent manner. In a database, the values in the fields are 'null'." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:documentation a owl:DatatypeProperty ;
    rdfs:label "documentation" ;
    skos:definition "A URL of the project documentation." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:embargoPeriod a owl:ObjectProperty ;
    rdfs:label "embargoPeriod" ;
    rdfs:range oep:Embargoperiod ;
    skos:definition "An object that describes the embargo period during which public access to the data is not allowed." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:encoding a owl:DatatypeProperty ;
    rdfs:label "encoding" ;
    skos:definition "Specifies the character encoding of the resource's data file. The default is 'UTF-8'. The values should be one of the 'Preferred MIME Names'." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:extent a owl:ObjectProperty ;
    rdfs:label "extent" ;
    rdfs:range oep:Extent ;
    skos:definition "An object that describes a covered area or region." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:extent_name a owl:DatatypeProperty ;
    rdfs:label "extent_name" ;
    skos:definition "The name of the region." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:field_description a owl:DatatypeProperty ;
    rdfs:label "field_description" ;
    skos:definition "A text describing the field." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:field_name a owl:DatatypeProperty ;
    rdfs:label "field_name" ;
    skos:definition "The name of the field. The name may only consist of lowercase alphanumeric characters or underscores. It must not begin with a number or an underscore." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:format a owl:DatatypeProperty ;
    rdfs:label "format" ;
    skos:definition "A file extension format. Possible options are 'csv', 'xlsx', 'json', 'PostgreSQL', 'SQLite' and other standard file extensions." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:fundingAgency a owl:DatatypeProperty ;
    rdfs:label "fundingAgency" ;
    skos:definition "A name of the entity providing the funding. This can be a government agency or a company." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:fundingAgencyLogo a owl:DatatypeProperty ;
    rdfs:label "fundingAgencyLogo" ;
    skos:definition "A URL to the logo or image of the funding agency." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:grantNo a owl:DatatypeProperty ;
    rdfs:label "grantNo" ;
    skos:definition "An identifying grant number. In case of a publicly funded project, this number is assigned by the funding agency." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:homepage a owl:DatatypeProperty ;
    rdfs:label "homepage" ;
    skos:definition "A URL of the project." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:isActive a owl:DatatypeProperty ;
    rdfs:label "isActive" ;
    skos:definition "A boolean key that indicates if the embargo period is currently active. Must be changed to False on the embargo period end date." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:isabout_name a owl:DatatypeProperty ;
    rdfs:label "isabout_name" ;
    skos:definition "The class label of the ontology term." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:latitude a owl:DatatypeProperty ;
    rdfs:label "latitude" ;
    skos:definition "The latitude (lat) information of the location. Specifies the north / south position of the geometry." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:license_name a owl:DatatypeProperty ;
    rdfs:label "license_name" ;
    skos:definition "The SPDX identifier." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:license_title a owl:DatatypeProperty ;
    rdfs:label "license_title" ;
    skos:definition "The official (human readable) title of the license." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:location a owl:ObjectProperty ;
    rdfs:label "location" ;
    rdfs:range oep:Location ;
    skos:definition "An object that describes a covered area or region." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:longitude a owl:DatatypeProperty ;
    rdfs:label "longitude" ;
    skos:definition "The longitude (lon) information of the location. Specifies the east / west position of the geometry." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:metaMetadata a owl:ObjectProperty ;
    rdfs:label "metaMetadata" ;
    rdfs:range oep:Metametadata ;
    skos:definition "An object that describes the metadata themselves, their format, version and license." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:metadataLicense a owl:ObjectProperty ;
    rdfs:label "metadataLicense" ;
    rdfs:range oep:Metadatalicense ;
    skos:definition "The license of the OEMetadata. " ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:metadataVersion a owl:DatatypeProperty ;
    rdfs:label "metadataVersion" ;
    skos:definition "Type and version number of the metadata." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:metadatalicense_name a owl:DatatypeProperty ;
    rdfs:label "metadatalicense_name" ;
    skos:definition "The SPDX identifier." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:metadatalicense_title a owl:DatatypeProperty ;
    rdfs:label "metadatalicense_title" ;
    skos:definition "The official (human readable) title of the license." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:nullable a owl:DatatypeProperty ;
    rdfs:label "nullable" ;
    skos:definition "A boolean key to specify that a column can be nullable. True is the default value." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:object a owl:DatatypeProperty ;
    rdfs:label "object" ;
    skos:definition "The object of the contribution. Which part of the package was supplied or changed." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:organization a owl:DatatypeProperty ;
    rdfs:label "organization" ;
    skos:definition "A string describing the organization this contributor is affiliated to. This can be relevant for the copyright." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:publicationDate a owl:DatatypeProperty ;
    rdfs:label "publicationDate" ;
    skos:definition "A date of publication of the data or metadata. The date format is ISO 8601 (YYYY-MM-DD)." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:publicationYear a owl:DatatypeProperty ;
    rdfs:label "publicationYear" ;
    skos:definition "Indicates the year when the work was published." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:publisher a owl:DatatypeProperty ;
    rdfs:label "publisher" ;
    skos:definition "The publishing agency of the data. This can be the OEP." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:publisherLogo a owl:DatatypeProperty ;
    rdfs:label "publisherLogo" ;
    skos:definition "A URL to the logo of the publishing agency of data." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:reference a owl:ObjectProperty ;
    rdfs:label "reference" ;
    rdfs:range oep:Reference ;
    skos:definition "The reference to the foreign table." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:referenceDate a owl:DatatypeProperty ;
    rdfs:label "referenceDate" ;
    skos:definition "A base year, month or day. The time for which the data should be accurate. Date Format is ISO 8601." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:resource a owl:DatatypeProperty ;
    rdfs:label "resource" ;
    skos:definition "The referenced foreign table." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:resource_description a owl:DatatypeProperty ;
    rdfs:label "resource_description" ;
    skos:definition "A description of the table. It should be usable as summary information for the table that is described by the metadata." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:resource_name a owl:DatatypeProperty ;
    rdfs:label "resource_name" ;
    skos:definition "A filename or database conform table name." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:resource_title a owl:DatatypeProperty ;
    rdfs:label "resource_title" ;
    skos:definition "A human readable resource or table name." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:review a owl:ObjectProperty ;
    rdfs:label "review" ;
    rdfs:range oep:Review ;
    skos:definition "The metadata on the OEP can go through an open peer review process. See the Academy course [Open Peer Review](https://openenergyplatform.github.io/academy/courses/09_peer_review/) for further information." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:schema a owl:ObjectProperty ;
    rdfs:label "schema" ;
    rdfs:range oep:Schema ;
    skos:definition "An object that describes the structure of a table. It contains all fields (columns of the table), the primary key and optional foreign keys." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:sourceCode a owl:DatatypeProperty ;
    rdfs:label "sourceCode" ;
    skos:definition "A URL of the source code of the project." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:source_description a owl:DatatypeProperty ;
    rdfs:label "source_description" ;
    skos:definition "A free text description of the source." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:source_title a owl:DatatypeProperty ;
    rdfs:label "source_title" ;
    skos:definition "A human readable title of the source, a document title or organisation name." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:sourcelicense_name a owl:DatatypeProperty ;
    rdfs:label "sourcelicense_name" ;
    skos:definition "The SPDX identifier." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:sourcelicense_title a owl:DatatypeProperty ;
    rdfs:label "sourcelicense_title" ;
    skos:definition "The official (human readable) title of the license." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:spatial a owl:ObjectProperty ;
    rdfs:label "spatial" ;
    rdfs:range oep:Spatial ;
    skos:definition "An object that describes the spatial context of the data." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:subject_name a owl:DatatypeProperty ;
    rdfs:label "subject_name" ;
    skos:definition "A class label of the ontology term." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:temporal a owl:ObjectProperty ;
    rdfs:label "temporal" ;
    rdfs:range oep:Temporal ;
    skos:definition "An object with the time period covered in the data. Temporal information should contain a \"referenceDate\" or the keys that describe a time series, or both." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:unit a owl:DatatypeProperty ;
    rdfs:label "unit" ;
    skos:definition "The unit of a field. If it does not apply, use 'null'. If the unit is given in a separate field, reference this field (e.g. 'unit'). Use a space between numbers and units (100 m)." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:value a owl:DatatypeProperty ;
    rdfs:label "value" ;
    skos:definition "The name of the value in the column." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:valuereference_name a owl:DatatypeProperty ;
    rdfs:label "valuereference_name" ;
    skos:definition "The class label of the ontology term in the column." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:attribution a owl:DatatypeProperty ;
    rdfs:label "attribution" ;
    skos:definition "A copyright holder of the data. Must be provided if attribution licenses are used." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:copyrightStatement a owl:DatatypeProperty ;
    rdfs:label "copyrightStatement" ;
    skos:definition "A link or path that proves that the source or data has the appropriate license. This can be a page number or website imprint." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:end a owl:DatatypeProperty ;
    rdfs:label "end" ;
    skos:definition "The temporal end point of a time series." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:fields a owl:DatatypeProperty ;
    rdfs:label "fields" ;
    skos:definition "The foreign resource column." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:instruction a owl:DatatypeProperty ;
    rdfs:label "instruction" ;
    skos:definition "A short description of rights and obligations. The use of tl;drLegal is recommended." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:resolutionUnit a owl:DatatypeProperty ;
    rdfs:label "resolutionUnit" ;
    skos:definition "The unit of the temporal resolution." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:resolutionValue a owl:DatatypeProperty ;
    rdfs:label "resolutionValue" ;
    skos:definition "The time span between individual information points in a time series. The value of the resolution." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:start a owl:DatatypeProperty ;
    rdfs:label "start" ;
    skos:definition "The start time of a time series." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:type a owl:DatatypeProperty ;
    rdfs:label "type" ;
    skos:definition "The data type of the field. In case of a geom column in a database, also indicate the shape and CRS." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:path a owl:DatatypeProperty ;
    rdfs:label "path" ;
    skos:definition "A link or path to the license text." ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .


