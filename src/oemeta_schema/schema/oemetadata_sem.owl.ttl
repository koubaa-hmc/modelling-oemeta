        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:path ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:sourcelicense_title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:attribution ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:sourcelicense_title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:instruction ],
        [ a owl:Restriction ;
