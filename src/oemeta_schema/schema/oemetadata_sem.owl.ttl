            owl:onProperty oep:fields ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:primaryKey ] ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:Source a owl:Class ;
    rdfs:label "Source" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
