            owl:onProperty oep:path ],
        [ a owl:Restriction ;
            owl:allValuesFrom oep:Sourcelicense ;
            owl:onProperty oep:sourceLicenses ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:authors ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:source_title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:publicationYear ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:path ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:publicationYear ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:source_title ],
