            owl:minCardinality 0 ;
            owl:onProperty oep:publicationDate ] ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:Review a owl:Class ;
    rdfs:label "Review" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:path ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oep:badge ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:path ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:badge ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oep:badge ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oep:path ] ;
    skos:inScheme <https://openenergyplatform.org/metadata/v20> .

oep:Schema a owl:Class ;
