            }
        },

        {
            "@id": "oep:resource_name",
            "@type": "rdf:Property",
            "rdfs:label": "resource_name",
            "skos:definition": "A filename or database conform table name.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:contact",
            "@type": "rdf:Property",
            "rdfs:label": "contact",
            "skos:definition": "A reference to the creator or maintainer of the data set. This can be an email address or a GitHub handle.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:license_title",
            "@type": "rdf:Property",
            "rdfs:label": "license_title",
            "skos:definition": "The official (human readable) title of the license.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:embargoPeriod",
            "@type": "rdf:Property",
            "rdfs:label": "embargoPeriod",
            "rdfs:range": {
                "@id": "oep:Embargoperiod"
            },
            "skos:definition": "An object that describes the embargo period during which public access to the data is not allowed.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:dataset_name",
            "@type": "rdf:Property",
            "rdfs:label": "dataset_name",
            "skos:definition": "A filename or database conform dataset name.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:crs",
            "@type": "rdf:Property",
            "rdfs:label": "crs",
            "skos:definition": "The Coordinate Reference System, specified as an EPSG code.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:copyrightStatement",
            "@type": "rdf:Property",
            "rdfs:label": "copyrightStatement",
            "skos:definition": "A link or path that proves that the source or data has the appropriate license. This can be a page number or website imprint.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:instruction",
            "@type": "rdf:Property",
            "rdfs:label": "instruction",
            "skos:definition": "A short description of rights and obligations. The use of tl;drLegal is recommended.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:temporal",
            "@type": "rdf:Property",
            "rdfs:label": "temporal",
            "rdfs:range": {
                "@id": "oep:Temporal"
            },
            "skos:definition": "An object with the time period covered in the data. Temporal information should contain a \"referenceDate\" or the keys that describe a time series, or both.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:resource_title",
            "@type": "rdf:Property",
            "rdfs:label": "resource_title",
            "skos:definition": "A human readable resource or table name.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:Resource",
            "@type": "rdfs:Class",
            "rdfs:label": "Resource",

            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },

        {
            "@id": "oep:decimalSeparator",
            "@type": "rdf:Property",
            "rdfs:label": "decimalSeparator",
            "skos:definition": "The symbol used to separate the integer part from the fractional part of a number written in decimal form. Depending on language and region this symbol can be '.' or ','.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:dataset_description",
            "@type": "rdf:Property",
            "rdfs:label": "dataset_description",
            "skos:definition": "A free text description of the dataset.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:Temporal",
            "@type": "rdfs:Class",
            "rdfs:label": "Temporal",

            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },

        {
            "@id": "oep:review",
            "@type": "rdf:Property",
            "rdfs:label": "review",
            "rdfs:range": {
                "@id": "oep:Review"
            },
            "skos:definition": "The metadata on the OEP can go through an open peer review process. See the Academy course [Open Peer Review](https://openenergyplatform.github.io/academy/courses/09_peer_review/) for further information.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:extent",
            "@type": "rdf:Property",
            "rdfs:label": "extent",
            "rdfs:range": {
                "@id": "oep:Extent"
            },
            "skos:definition": "An object that describes a covered area or region.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:publicationDate",
            "@type": "rdf:Property",
            "rdfs:label": "publicationDate",
            "skos:definition": "A date of publication of the data or metadata. The date format is ISO 8601 (YYYY-MM-DD).",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:Schema",
            "@type": "rdfs:Class",
            "rdfs:label": "Schema",

            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },

        {
            "@id": "oep:keywords",
            "@type": "rdf:Property",
            "rdfs:label": "keywords",
            "skos:definition": "An array of freely selectable keywords that help with searching and structuring.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:metaMetadata",
            "@type": "rdf:Property",
            "rdfs:label": "metaMetadata",
            "rdfs:range": {
                "@id": "oep:Metametadata"
            },
            "skos:definition": "An object that describes the metadata themselves, their format, version and license.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:field_name",
            "@type": "rdf:Property",
            "rdfs:label": "field_name",
            "skos:definition": "The name of the field. The name may only consist of lowercase alphanumeric characters or underscores. It must not begin with a number or an underscore.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:metadatalicense_title",
            "@type": "rdf:Property",
            "rdfs:label": "metadatalicense_title",
            "skos:definition": "The official (human readable) title of the license.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:nullable",
            "@type": "rdf:Property",
            "rdfs:label": "nullable",
            "skos:definition": "A boolean key to specify that a column can be nullable. True is the default value.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:spatial",
            "@type": "rdf:Property",
            "rdfs:label": "spatial",
            "rdfs:range": {
                "@id": "oep:Spatial"
            },
            "skos:definition": "An object that describes the spatial context of the data.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:extent_name",
            "@type": "rdf:Property",
            "rdfs:label": "extent_name",
            "skos:definition": "The name of the region.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:delimiter",
            "@type": "rdf:Property",
            "rdfs:label": "delimiter",
            "skos:definition": "The delimiter specifies the character sequence which should separate fields (columns). Common characters are ',' (comma), ';' (semicolon), '.' (point) and '\\t' (tab).",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:resource_description",
            "@type": "rdf:Property",
            "rdfs:label": "resource_description",
            "skos:definition": "A description of the table. It should be usable as summary information for the table that is described by the metadata.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:Spatial",
            "@type": "rdfs:Class",
            "rdfs:label": "Spatial",

            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },

        {
            "@id": "oep:context_title",
            "@type": "rdf:Property",
            "rdfs:label": "context_title",
            "skos:definition": "A title of the associated project.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:aggregationType",
            "@type": "rdf:Property",
            "rdfs:label": "aggregationType",
            "skos:definition": "An indicator of whether the values are a sum, an average or a current value.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:Timeserie",
            "@type": "rdfs:Class",
            "rdfs:label": "Timeserie",

            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },

        {
            "@id": "oep:fundingAgency",
            "@type": "rdf:Property",
            "rdfs:label": "fundingAgency",
            "skos:definition": "A name of the entity providing the funding. This can be a government agency or a company.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:date",
            "@type": "rdf:Property",
            "rdfs:label": "date",
            "skos:definition": "The date of the contribution. Date Format is ISO 8601.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:timeseries",
            "@type": "rdf:Property",
            "rdfs:label": "timeseries",
            "rdfs:range": {
                "@id": "oep:Timeserie"
            },
            "skos:definition": "An array that describe the timeseries.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:License",
            "@type": "rdfs:Class",
            "rdfs:label": "License",

            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },

        {
            "@id": "oep:fields",
            "@type": "rdf:Property",
            "rdfs:label": "fields",
            "skos:definition": "The foreign resource column.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:Foreignkey",
            "@type": "rdfs:Class",
            "rdfs:label": "Foreignkey",

            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },

        {
            "@id": "oep:languages",
            "@type": "rdf:Property",
            "rdfs:label": "languages",
            "skos:definition": "An array of languages used within the described data structures (e.g. titles, descriptions) or metadata.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:longitude",
            "@type": "rdf:Property",
            "rdfs:label": "longitude",
            "skos:definition": "The longitude (lon) information of the location. Specifies the east / west position of the geometry.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:field_description",
            "@type": "rdf:Property",
            "rdfs:label": "field_description",
            "skos:definition": "A text describing the field.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:unit",
            "@type": "rdf:Property",
            "rdfs:label": "unit",
            "skos:definition": "The unit of a field. If it does not apply, use 'null'. If the unit is given in a separate field, reference this field (e.g. 'unit'). Use a space between numbers and units (100 m).",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:publicationYear",
            "@type": "rdf:Property",
            "rdfs:label": "publicationYear",
            "skos:definition": "Indicates the year when the work was published.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:metadataVersion",
            "@type": "rdf:Property",
            "rdfs:label": "metadataVersion",
            "skos:definition": "Type and version number of the metadata.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:source_title",
            "@type": "rdf:Property",
            "rdfs:label": "source_title",
            "skos:definition": "A human readable title of the source, a document title or organisation name.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:authors",
            "@type": "rdf:Property",
            "rdfs:label": "authors",
            "skos:definition": "An array of the full names of the authors of the source material.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:start",
            "@type": "rdf:Property",
            "rdfs:label": "start",
            "skos:definition": "The start time of a time series.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:Location",
            "@type": "rdfs:Class",
            "rdfs:label": "Location",

            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },

        {
            "@id": "oep:type",
            "@type": "rdf:Property",
            "rdfs:label": "type",
            "skos:definition": "The data type of the field. In case of a geom column in a database, also indicate the shape and CRS.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:subject_name",
            "@type": "rdf:Property",
            "rdfs:label": "subject_name",
            "skos:definition": "A class label of the ontology term.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:sourceCode",
            "@type": "rdf:Property",
            "rdfs:label": "sourceCode",
            "skos:definition": "A URL of the source code of the project.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:boundingBox",
            "@type": "rdf:Property",
            "rdfs:label": "boundingBox",
            "skos:definition": "The covered area specified by the coordinates of a bounding box. The format is [minLon, minLat, maxLon, maxLat] or [W,S,E,N].",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:homepage",
            "@type": "rdf:Property",
            "rdfs:label": "homepage",
            "skos:definition": "A URL of the project.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:Metametadata",
            "@type": "rdfs:Class",
            "rdfs:label": "Metametadata",

            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },

        {
            "@id": "oep:publisherLogo",
            "@type": "rdf:Property",
            "rdfs:label": "publisherLogo",
            "skos:definition": "A URL to the logo of the publishing agency of data.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
            }
        },
        {
            "@id": "oep:resources",
            "@type": "rdf:Property",
            "rdfs:label": "resources",
            "rdfs:range": {
                "@id": "oep:Resource"
            },
            "skos:definition": "A collection of related resources.",
            "skos:inScheme": {
                "@id": "https://openenergyplatform.org/metadata/v20"
